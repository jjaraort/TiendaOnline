
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="mt-4">Categorias</h1>
<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="index.html">Resumen</a></li>
    <li class="breadcrumb-item active">Categorias</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-book me-1"></i> Lista de Categorias
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModal(null)">Crear Nueva</button>
            </div>
        </div>

        <hr />

        <table id="tabla" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th>Descripcion</th>
                    <th>Activo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="FormModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="exampleModalLabel">Categoria</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />
                <div class="row g-2">

                    <div class="col-sm-6">
                        <label for="txtapellido" class="form-label">Descripcion</label>
                        <input type="text" class="form-control" id="txtdescripcion">
                    </div>

                    <div class="col-sm-6">
                        <label for="cboactivo" class="form-label">Activo</label>
                        <select class="form-select" id="cboactivo">
                            <option value="1" selected>Si</option>
                            <option value="0">No</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12">
                    <div id="mensajeError" class="alert alert-danger" role="alert">
                        Los campos son obligatorios.
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="Guardar()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script>
    var tabladata;
    var filaSeleccionada;

    $(document).ready(function () {

        tabladata = $("#tabla").DataTable({
            responsive: true,
            ordering: false,
            ajax: {
                url: '@Url.Action("ListarCategoria", "Mantenedor")',
                type: "GET",
                dataType: "json",
                dataSrc: "data"
            },
            columns: [
                { data: "Descripcion" },
                {
                    data: "Activo",
                    render: function (valor) {
                        return valor
                            ? '<span class="badge bg-success">Sí</span>'
                            : '<span class="badge bg-danger">No</span>';
                    }
                },
                {
                    defaultContent:
                        '<button type="button" class="btn btn-primary btn-sm btn-editar"><i class="fas fa-pen"></i></button>' +
                        '<button type="button" class="btn btn-danger btn-sm ms-2 btn-eliminar"><i class="fas fa-trash"></i></button>',
                    orderable: false,
                    searchable: false,
                    width: "90px",
                    className: "text-center"
                }
            ],
            language: {
                url: "https://cdn.datatables.net/plug-ins/2.3.7/i18n/es-ES.json"
            }
        });

        //EDITAR
        $("#tabla tbody").on("click", ".btn-editar", function () {
            filaSeleccionada = $(this).closest("tr");
            
            if (filaSeleccionada.hasClass("child")) {
                filaSeleccionada = filaSeleccionada.prev();
            }

            var data = tabladata.row(filaSeleccionada).data();
            abrirModal(data);
        });

        //ELIMINAR
        $("#tabla tbody").on("click", ".btn-eliminar", function () {

            var fila = $(this).closest("tr");
            var data = tabladata.row(fila).data();

            swal({
                title: "¿Está seguro?",
                text: "¿Desea eliminar la categoría?",
                type: "warning",
                showCancelButton: true,
                confirmButtonText: "Sí",
                cancelButtonText: "No"
            },
            function () {
                jQuery.ajax({
                    url: '@Url.Action("EliminarCategoria", "Mantenedor")',
                    type: "POST",
                    data: JSON.stringify({ id: data.IdCategoria }),
                    dataType: "json",
                    contentType: "application/json; charset=utf-8",
                    success: function (data) {
                        if (data.resultado) {
                            tabladata.row(fila).remove().draw();
                        } else {
                            swal("No se pudo eliminar la categoría", data.mensaje, "error");
                        }
                    }
                });
            });
        });

    });

    //MODAL
    function abrirModal(json) {
        $("#txtid").val(0);
        $("#txtdescripcion").val("");
        $("#cboactivo").val(1);
        $("#mensajeError").hide();

        if (json != null) {
            $("#txtid").val(json.IdCategoria || 0);
            $("#txtdescripcion").val(json.Descripcion);
            $("#cboactivo").val(json.Activo ? 1 : 0);
        }

        var modal = new bootstrap.Modal(document.getElementById('FormModal'));
        modal.show();
    }

    //GUARDAR
    function Guardar() {

        var Categoria = {
            IdCategoria: parseInt($("#txtid").val() || 0, 10),
            Descripcion: $("#txtdescripcion").val(),
            Activo: $("#cboactivo").val() == 1 ? true : false
        };

        if (!Categoria.Descripcion) {
            $("#mensajeError").text("La descripción es obligatoria.");
            $("#mensajeError").show();
            return;
        }

        $.ajax({
            url: '@Url.Action("GuardarCategoria", "Mantenedor")',
            type: "POST",
            data: JSON.stringify({ objeto: Categoria }),
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            success: function (data) {

                if (Categoria.IdCategoria === 0) {
                    // NUEVO
                    if (data.resultado != 0) {
                        Categoria.IdCategoria = data.resultado;
                        tabladata.row.add(Categoria).draw(false);
                        $("#FormModal").modal("hide");
                    } else {
                        $("#mensajeError").text(data.mensaje);
                        $("#mensajeError").show();
                    }
                } else {
                    // EDITAR
                    if (data.resultado) {
                        tabladata.row(filaSeleccionada).data(Categoria).draw(false);
                        filaSeleccionada = null;
                        $("#FormModal").modal("hide");
                    } else {
                        $("#mensajeError").text(data.mensaje);
                        $("#mensajeError").show();
                    }
                }
            },
            error: function () {
                $("#mensajeError").text("Error Ajax");
                $("#mensajeError").show();
            }
        });
    }
    </script>
}